{{!
    @template block_dimensions/competency_card

    Competency card template for block_dimensions.

    WCAG 2.1 A/AA accessibility design notes:
    - Pseudo-link card pattern: only the card title is a real <a>, marked
      .stretched-link so a CSS ::after overlay makes the visible card area
      clickable. This keeps the link's accessible name short (just the
      competency name) and frees the favourite button from being nested in an
      anchor (WCAG 2.4.4 Link Purpose, 2.5.3 Label in Name, 4.1.1 Parsing).
    - Decorative gradient/halftone backgrounds are aria-hidden; only real photo
      images use role="img" with aria-label (WCAG 1.1.1).
    - Tag chips are exposed to AT inside a labelled group (WCAG 1.3.1).
    - The favourite button declares aria-pressed for explicit toggle semantics
      (WCAG 4.1.2).

    Example context (json):
    {
        "id": 100,
        "name": "Competency",
        "url": "#",
        "hasimage": false,
        "hastag1": true,
        "tag1": "2026",
        "hastag2": true,
        "tag2": "Category",
        "isfavourite": false,
        "buttonlabel": "Access"
    }
}}
<article class="card competency-card h-100" aria-labelledby="competency-title-{{id}}" style="{{#hasbgcolor}}--dimension-custombgcolor: {{bgcolor}};{{/hasbgcolor}}{{#hastextcolor}}--dimension-customtextcolor: {{textcolor}};{{/hastextcolor}}">
    <button type="button"
            class="dims-fav-btn"
            data-fav-type="competency"
            data-fav-id="{{id}}"
            aria-label="{{favouritearialabel}}"
            aria-pressed="{{#isfavourite}}true{{/isfavourite}}{{^isfavourite}}false{{/isfavourite}}"
            title="{{favouritetitle}}">
        {{#isfavourite}}
        <i class="fa fa-star dims-fav-icon-filled" aria-hidden="true"></i>
        {{/isfavourite}}
        {{^isfavourite}}
        <i class="fa fa-star-o dims-fav-icon-empty" aria-hidden="true"></i>
        {{/isfavourite}}
    </button>
    <div class="competency-card-image-wrapper">
        {{#hasimage}}
        <div class="competency-card-image"
             role="img"
             aria-label="{{name}}"
             style="background-image: url('{{imageurl}}');">
        </div>
        {{/hasimage}}
        {{^hasimage}}
        <div class="competency-card-image competency-card-gradient{{#hasbgcolor}} has-custom-bg{{/hasbgcolor}}"
             aria-hidden="true"
             style="{{#hasbgcolor}}background: var(--dimension-custombgcolor);{{/hasbgcolor}}">
        </div>
        {{/hasimage}}
        {{#hastags}}
        <div class="dimension-tags" role="group" aria-label="{{#str}}cardtags, block_dimensions{{/str}}">
            {{#tags}}
            <span class="dimension-tag cm-tag">{{value}}</span>
            {{/tags}}
        </div>
        {{/hastags}}
        <span class="dims-card-access-btn" aria-hidden="true">
            {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
        </span>
    </div>
    <div class="card-body p-3">
        <h4 class="card-title mb-0 font-weight-bold text-dark" id="competency-title-{{id}}">
            <a href="{{url}}" class="competency-card-link stretched-link text-decoration-none text-dark">{{name}}</a>
        </h4>
    </div>
</article>
