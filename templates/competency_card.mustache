{{!
    Competency card template for block_dimensions.

    WCAG 2.2 Accessibility Features:
    - Semantic <article> element for card content
    - aria-labelledby linking to the card title
    - role="img" with aria-label for decorative/custom images
    - aria-hidden for purely decorative elements
    - Visible focus indicator via CSS

    Context variables required for this template:
    * id - Competency ID
    * name - Competency name
    * url - Link to view-plan.php
    * imageurl - Custom card image URL (optional)
    * hasimage - Boolean indicating if image exists
    * tag1 - First tag label (optional)
    * hastag1 - Boolean indicating if tag1 exists
    * tag2 - Second tag label (optional)
    * hastag2 - Boolean indicating if tag2 exists
}}
<article class="card competency-card h-100" aria-labelledby="competency-title-{{id}}">
    <a href="{{url}}" 
       class="competency-card-link text-decoration-none d-flex flex-column h-100"
       aria-describedby="competency-title-{{id}}">
        <div class="competency-card-image-wrapper">
            {{#hasimage}}
            <div class="competency-card-image" 
                 role="img" 
                 aria-label="{{name}}"
                 style="background-image: url('{{imageurl}}');">
            </div>
            {{/hasimage}}
            {{^hasimage}}
            <div class="competency-card-image competency-card-gradient" 
                 role="presentation" 
                 aria-hidden="true">
            </div>
            {{/hasimage}}
            {{#hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag">{{tag1}}</span>
                <span class="dimension-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{#hastag1}}{{^hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag">{{tag1}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{^hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            <span class="dims-card-access-btn" aria-hidden="true">
                {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
            </span>
        </div>
        <div class="card-body p-3">
            <h6 class="card-title mb-0 font-weight-bold text-dark" id="competency-title-{{id}}">
                {{name}}
            </h6>
        </div>
    </a>
</article>
