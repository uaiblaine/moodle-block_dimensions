{{!
    @template block_dimensions/competency_card

    Competency card template for block_dimensions.

    WCAG 2.2 Accessibility Features:
    - Semantic <article> element for card content
    - aria-labelledby linking to the card title
    - role="img" with aria-label for decorative/custom images
    - aria-hidden for purely decorative elements
    - Visible focus indicator via CSS

    Example context (json):
    {
        "id": 100,
        "name": "Competency",
        "url": "#",
        "hasimage": false,
        "hastag1": true,
        "tag1": "2026",
        "hastag2": true,
        "tag2": "Category",
        "isfavourite": false,
        "buttonlabel": "Access"
    }
}}
<article class="card competency-card h-100" aria-labelledby="competency-title-{{id}}" style="{{#hasbgcolor}}--dimension-custombgcolor: {{bgcolor}};{{/hasbgcolor}}{{#hastextcolor}}--dimension-customtextcolor: {{textcolor}};{{/hastextcolor}}">
    <a href="{{url}}" 
       class="competency-card-link text-decoration-none d-flex flex-column h-100"
       aria-describedby="competency-title-{{id}}">
        <div class="competency-card-image-wrapper">
            {{#hasimage}}
            <div class="competency-card-image" 
                 role="img" 
                 aria-label="{{name}}"
                 style="background-image: url('{{imageurl}}');">
            </div>
            {{/hasimage}}
            {{^hasimage}}
            <div class="competency-card-image competency-card-gradient{{#hasbgcolor}} has-custom-bg{{/hasbgcolor}}" 
                 role="presentation" 
                 aria-hidden="true"
                 style="{{#hasbgcolor}}background: var(--dimension-custombgcolor);{{/hasbgcolor}}">
            </div>
            {{/hasimage}}
            {{#hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag cm-tag">{{tag1}}</span>
                <span class="dimension-tag cm-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{#hastag1}}{{^hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag cm-tag">{{tag1}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{^hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag cm-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            <span class="dims-card-access-btn" aria-hidden="true">
                {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
            </span>
            <button type="button"
                    class="dims-fav-btn"
                    data-fav-type="competency"
                    data-fav-id="{{id}}"
                    aria-label="{{#isfavourite}}{{#str}}removefromfavourites, block_dimensions{{/str}}{{/isfavourite}}{{^isfavourite}}{{#str}}addtofavourites, block_dimensions{{/str}}{{/isfavourite}}"
                    title="{{#isfavourite}}{{#str}}removefromfavourites, block_dimensions{{/str}}{{/isfavourite}}{{^isfavourite}}{{#str}}addtofavourites, block_dimensions{{/str}}{{/isfavourite}}">
                {{#isfavourite}}
                <i class="fa fa-star dims-fav-icon-filled" aria-hidden="true"></i>
                {{/isfavourite}}
                {{^isfavourite}}
                <i class="fa fa-star-o dims-fav-icon-empty" aria-hidden="true"></i>
                {{/isfavourite}}
            </button>
        </div>
        <div class="card-body p-3">
            <h6 class="card-title mb-0 font-weight-bold text-dark" id="competency-title-{{id}}">
                {{name}}
            </h6>
        </div>
    </a>
</article>
