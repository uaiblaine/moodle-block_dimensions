{{!
    @template block_dimensions/summary

    Summary template for block_dimensions (hybrid lazy-load mode).

    Initial HTML is intentionally minimal. The complete dataset is fetched
    client-side through one non-paginated endpoint and rendered incrementally.

    Example context (json):
    {
        "containerid": "block_dimensions_1",
        "showheading": true,
        "showsearch": true,
        "showsectionheaders": true,
        "endpointmethod": "block_dimensions_get_block_dataset",
        "filtersettingsjson": "{}",
        "favouritesenabled": true
    }
}}
<div id="{{containerid}}" class="block-dimensions-content" role="region" aria-label="{{#str}}mycompetencies, block_dimensions{{/str}}">
    <div class="dims-block-header">
        {{#showheading}}
        <h2 class="dims-block-heading" id="block-dimensions-heading-{{containerid}}">
            {{#str}}mycompetencies, block_dimensions{{/str}}
        </h2>
        {{/showheading}}
        {{#showsearch}}
        <div class="dims-search-row">
            <div class="dims-block-search-wrapper">
                <label for="dims-block-search-{{containerid}}" class="sr-only">
                    {{#str}}searchlabel, block_dimensions{{/str}}
                </label>
                <i class="fa fa-search dims-block-search-icon" aria-hidden="true"></i>
                <input type="text"
                       id="dims-block-search-{{containerid}}"
                       class="dims-block-search-input"
                       placeholder="{{#str}}search_placeholder, block_dimensions{{/str}}"
                       autocomplete="off" />
                <button type="button" class="dims-block-search-clear" aria-label="{{#str}}clear, core{{/str}}" style="display:none;">
                    <i class="fa fa-times" aria-hidden="true"></i>
                </button>
            </div>
            <button type="button"
                    class="dims-filter-toggle-btn"
                    aria-expanded="false"
                    aria-label="{{#str}}togglefilters, block_dimensions{{/str}}">
                <i class="fa fa-sliders" aria-hidden="true"></i>
            </button>
        </div>
        {{/showsearch}}
    </div>

    <div class="dims-loading-state text-muted small" role="status" aria-live="polite">
        {{#str}}loading, core{{/str}}
    </div>

    <div class="dims-error-message alert alert-warning" role="alert" style="display:none;">
        <span class="dims-error-text"></span>
        <button type="button" class="btn btn-sm btn-outline-secondary dims-error-retry ml-2">
            {{#str}}retry, block_dimensions{{/str}}
        </button>
    </div>

    {{#showsectionheaders}}
    <h3 id="dims-section-plan-{{containerid}}" class="dims-section-header dims-section-header-plan" data-section-header="plan" style="display:none">
        {{#str}}sectionheader_plan_line1, block_dimensions{{/str}}<br>{{#str}}sectionheader_plan_line2, block_dimensions{{/str}}
    </h3>
    {{/showsectionheaders}}
    <div class="dims-filters-host" data-filters-type="plan"></div>
    {{!
        Each <nav> gets its own type-specific aria-label so they are
        distinguishable when navigating by landmark (WCAG 1.3.1, 2.4.6).
        Using aria-label rather than aria-labelledby on the section h3 avoids
        an empty/duplicate name when section headers are disabled.
    }}
    <nav aria-label="{{#str}}landmark_plans, block_dimensions{{/str}}">
        <ul class="row list-unstyled dims-plan-grid" role="list" data-cards-type="plan"></ul>
    </nav>

    {{#showsectionheaders}}
    <h3 id="dims-section-competency-{{containerid}}" class="dims-section-header dims-section-header-competency" data-section-header="competency" style="display:none">
        {{#str}}sectionheader_competency_line1, block_dimensions{{/str}}<br>{{#str}}sectionheader_competency_line2, block_dimensions{{/str}}
    </h3>
    {{/showsectionheaders}}
    <div class="dims-filters-host" data-filters-type="competency"></div>
    <nav aria-label="{{#str}}landmark_competencies, block_dimensions{{/str}}">
        <ul class="row list-unstyled" role="list" data-cards-type="competency"></ul>
    </nav>

    <p class="text-muted small dims-empty-state" role="status" aria-live="polite" style="display:none;"></p>

    <span class="sr-only" data-results-status role="status" aria-live="polite"></span>
    <span class="sr-only" data-fav-status role="status" aria-live="assertive"></span>

    <noscript>
        <p class="dims-noscript" role="status">{{#str}}javascriptrequired, block_dimensions{{/str}}</p>
    </noscript>
</div>
{{#js}}
require(['block_dimensions/filters'], function(Filters) {
    Filters.init({
        containerid: '{{containerid}}',
        endpointmethod: '{{endpointmethod}}',
        filtersettings: {{{filtersettingsjson}}},
        favouritesenabled: {{favouritesenabled}},
        labels: {{{labelsjson}}}
    });
});
{{/js}}
