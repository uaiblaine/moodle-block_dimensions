{{!
    @template block_dimensions/filters

    Filter bar template for block_dimensions.

    Renders filter controls (tabs or dropdown) for tag1/tag2 custom fields.
    Used for both competency and plan filters.

    Example context (json):
    {
        "filters": [
            {
                "field": "competency_tag1",
                "label": "Year",
                "alllabel": "All",
                "istabs": true,
                "isdropdown": false,
                "options": [
                    {"value": "2026", "label": "2026"}
                ]
            }
        ]
    }
}}
<div class="dims-filters-bar" role="toolbar" aria-label="{{#str}}filterall, block_dimensions{{/str}}">
    {{#filters}}
        {{#istabs}}
        <div class="dims-filter-tabs-wrapper" data-filter-group="{{field}}">
            <div class="dims-filter-tabs" role="tablist">
                <button type="button"
                        class="dims-filter-tab active"
                        role="tab"
                        aria-selected="true"
                        data-filter-field="{{field}}"
                        data-filter-value="">
                    {{alllabel}}
                </button>
                {{#options}}
                <button type="button"
                        class="dims-filter-tab"
                        role="tab"
                        aria-selected="false"
                        data-filter-field="{{field}}"
                        data-filter-value="{{value}}">
                    {{label}}
                </button>
                {{/options}}
            </div>
        </div>
        {{/istabs}}
        {{#isdropdown}}
        <div class="dims-filter-dropdown-wrapper" data-filter-group="{{field}}">
            <select class="dims-filter-select"
                    data-filter-field="{{field}}"
                    aria-label="{{label}}">
                <option value="">{{alllabel}}</option>
                {{#options}}
                <option value="{{value}}">{{label}}</option>
                {{/options}}
            </select>
        </div>
        {{/isdropdown}}
    {{/filters}}
</div>
