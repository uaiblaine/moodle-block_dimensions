{{!
    @template block_dimensions/filters

    Filter bar template for block_dimensions — illustrative only.

    NOTE: at runtime the filter bar is built by string concatenation in
    amd/src/filters.js (renderFilterControls). This template is kept in sync
    for documentation purposes; edits here have no effect on the rendered
    output.

    Filter pills represent a mutually-exclusive selection of tag values, so
    they are exposed to assistive technology as a `radiogroup` of `radio`
    buttons (with `aria-checked`) rather than as `tab`/`tablist` (which would
    require an associated `tabpanel`). Dropdowns use the native <select>.

    Example context (json):
    {
        "filters": [
            {
                "field": "competency_tag1",
                "label": "Year",
                "alllabel": "All",
                "istabs": true,
                "isdropdown": false,
                "options": [
                    {"value": "2026", "label": "2026"}
                ]
            }
        ]
    }
}}
<div class="dims-filters-bar" role="toolbar" aria-label="{{#str}}filterall, block_dimensions{{/str}}">
    {{#filters}}
        {{#istabs}}
        <div class="dims-filter-tabs-wrapper" data-filter-group="{{field}}">
            <div class="dims-filter-tabs" role="radiogroup" aria-label="{{label}}">
                <button type="button"
                        class="dims-filter-tab active"
                        role="radio"
                        aria-checked="true"
                        tabindex="0"
                        data-filter-field="{{field}}"
                        data-filter-value="">
                    {{alllabel}}
                </button>
                {{#options}}
                <button type="button"
                        class="dims-filter-tab"
                        role="radio"
                        aria-checked="false"
                        tabindex="-1"
                        data-filter-field="{{field}}"
                        data-filter-value="{{value}}">
                    {{label}}
                </button>
                {{/options}}
            </div>
        </div>
        {{/istabs}}
        {{#isdropdown}}
        <div class="dims-filter-dropdown-wrapper" data-filter-group="{{field}}">
            <select class="dims-filter-select"
                    data-filter-field="{{field}}"
                    aria-label="{{label}}">
                <option value="">{{alllabel}}</option>
                {{#options}}
                <option value="{{value}}">{{label}}</option>
                {{/options}}
            </select>
        </div>
        {{/isdropdown}}
    {{/filters}}
</div>
