{{!
    Plan card template for block_dimensions with competency trail.

    WCAG 2.2 Accessibility Features:
    - Semantic <article> element for card content
    - aria-labelledby linking to the card title
    - Trail with clear visual indicators for completed/pending competencies

    Context variables required for this template:
    * id - Plan ID
    * name - Plan name
    * url - Link to view-plan.php
    * imageurl - Custom card image URL (optional)
    * hasimage - Boolean indicating if image exists
    * hastrail - Boolean indicating if trail data exists
    * trail - Array of competencies for the trail
    * competencycounttext - Textual competency count (e.g. 9 competencies)
    * hasitemsbeforetrail - Whether there are hidden competencies before the displayed trail
    * hasitemsaftertrail - Whether there are hidden competencies after the displayed trail
    * bgcolor - Custom background color (optional)
    * hasbgcolor - Boolean indicating if bgcolor exists
    * textcolor - Custom text color (optional)
    * hastextcolor - Boolean indicating if textcolor exists
    * tag1 - First tag label (optional)
    * hastag1 - Boolean indicating if tag1 exists
    * tag2 - Second tag label (optional)
    * trailclickable - Boolean indicating if trail items are clickable links
    * ishorizontal - Boolean indicating horizontal layout mode
    * isvertical - Boolean indicating vertical layout mode
}}
{{#isvertical}}
<article class="card plan-card h-100" aria-labelledby="plan-title-{{id}}" style="{{#hasbgcolor}}--dimension-custombgcolor: {{bgcolor}};{{/hasbgcolor}}{{#hastextcolor}}--dimension-customtextcolor: {{textcolor}};{{/hastextcolor}}">
    <a href="{{url}}" 
       class="plan-card-link text-decoration-none d-flex flex-column h-100"
       aria-describedby="plan-title-{{id}}">
        <div class="plan-card-image-wrapper">
            {{#hasimage}}
            <div class="plan-card-image" 
                 role="img" 
                 aria-label="{{name}}"
                 style="background-image: url('{{imageurl}}');"></div>
            {{/hasimage}}
            {{^hasimage}}
            <div class="plan-card-image plan-card-gradient{{#hasbgcolor}} has-custom-bg{{/hasbgcolor}}" 
                 role="presentation" 
                 aria-hidden="true"
                 style="{{#hasbgcolor}}background: var(--dimension-custombgcolor);{{/hasbgcolor}}"></div>
            {{/hasimage}}
            {{#hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag plan-tag">{{tag1}}</span>
                <span class="dimension-tag plan-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{#hastag1}}{{^hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag plan-tag">{{tag1}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{^hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag plan-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            <span class="dims-card-access-btn" aria-hidden="true">
                {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
            </span>
        </div>
        <div class="card-body p-3">
            <h6 class="card-title mb-2 font-weight-bold text-dark" id="plan-title-{{id}}">
                {{name}}
            </h6>
            <p class="competency-count-text">{{competencycounttext}}</p>
            {{#hastrail}}
            <div class="competency-trail{{#hasitemsbeforetrail}} has-before{{/hasitemsbeforetrail}}{{#hasitemsaftertrail}} has-after{{/hasitemsaftertrail}}" role="list" aria-label="{{#str}}competencytrail, block_dimensions{{/str}}">
                {{#trail}}
                <div class="trail-item {{#iscompleted}}completed{{/iscompleted}} {{#isfirst}}first{{/isfirst}} {{#islast}}last{{/islast}}{{#trailclickable}} clickable{{/trailclickable}}"
                     role="listitem"
                     {{#trailclickable}}data-href="{{url}}" title="{{shortname}}" onclick="event.preventDefault();event.stopPropagation();window.location.href=this.dataset.href;"{{/trailclickable}}>
                    <div class="trail-marker" aria-hidden="true">
                        {{#iscompleted}}
                        <i class="fa fa-check-circle text-success"></i>
                        {{/iscompleted}}
                        {{^iscompleted}}
                        <span class="empty-circle"></span>
                        {{/iscompleted}}
                    </div>
                    <span class="trail-label {{#iscompleted}}text-success{{/iscompleted}}">{{shortname}}</span>
                </div>
                {{/trail}}
            </div>
            {{/hastrail}}
        </div>
    </a>
</article>
{{/isvertical}}
{{#ishorizontal}}
<article class="card plan-card plan-card-horizontal h-100" aria-labelledby="plan-title-{{id}}" style="{{#hasbgcolor}}--dimension-custombgcolor: {{bgcolor}};{{/hasbgcolor}}{{#hastextcolor}}--dimension-customtextcolor: {{textcolor}};{{/hastextcolor}}">
    <a href="{{url}}"
    class="plan-card-link text-decoration-none d-flex h-100"
       aria-describedby="plan-title-{{id}}">
        <div class="plan-card-image-wrapper plan-card-image-wrapper-horizontal">
            {{#hasimage}}
            <div class="plan-card-image plan-card-image-horizontal"
                 role="img"
                 aria-label="{{name}}"
                 style="background-image: url('{{imageurl}}');"></div>
            {{/hasimage}}
            {{^hasimage}}
            <div class="plan-card-image plan-card-image-horizontal plan-card-gradient{{#hasbgcolor}} has-custom-bg{{/hasbgcolor}}"
                 role="presentation"
                 aria-hidden="true"
                 style="{{#hasbgcolor}}background: var(--dimension-custombgcolor);{{/hasbgcolor}}"></div>
            {{/hasimage}}
            <span class="dims-card-access-btn dims-card-access-btn-horizontal" aria-hidden="true">
                {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
            </span>
            {{#hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag plan-tag">{{tag1}}</span>
                <span class="dimension-tag plan-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{#hastag1}}{{^hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag plan-tag">{{tag1}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
            {{^hastag1}}{{#hastag2}}
            <div class="dimension-tags" aria-hidden="true">
                <span class="dimension-tag plan-tag">{{tag2}}</span>
            </div>
            {{/hastag2}}{{/hastag1}}
        </div>
        <div class="card-body plan-card-body-horizontal p-3">
            <h6 class="card-title mb-1 font-weight-bold text-dark" id="plan-title-{{id}}">
                {{name}}
            </h6>
            <p class="competency-count-text mb-2">{{competencycounttext}}</p>
            {{#hastrail}}
            <div class="competency-trail competency-trail-vertical{{#hasitemsbeforetrail}} has-before{{/hasitemsbeforetrail}}{{#hasitemsaftertrail}} has-after{{/hasitemsaftertrail}}" role="list" aria-label="{{#str}}competencytrail, block_dimensions{{/str}}">
                {{#trail}}
                <div class="trail-item trail-item-vertical {{#iscompleted}}completed{{/iscompleted}} {{#isfirst}}first{{/isfirst}} {{#islast}}last{{/islast}}{{#trailclickable}} clickable{{/trailclickable}}"
                     role="listitem"
                     {{#trailclickable}}data-href="{{url}}" title="{{shortname}}" onclick="event.preventDefault();event.stopPropagation();window.location.href=this.dataset.href;"{{/trailclickable}}>
                    <div class="trail-marker" aria-hidden="true">
                        {{#iscompleted}}
                        <i class="fa fa-check-circle text-success"></i>
                        {{/iscompleted}}
                        {{^iscompleted}}
                        <span class="empty-circle"></span>
                        {{/iscompleted}}
                    </div>
                    <span class="trail-label {{#iscompleted}}text-success{{/iscompleted}}">{{shortname}}</span>
                </div>
                {{/trail}}
            </div>
            {{/hastrail}}
        </div>
    </a>
</article>
{{/ishorizontal}}
