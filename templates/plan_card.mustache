{{!
    @template block_dimensions/plan_card

    Plan card template for block_dimensions with competency trail.

    WCAG 2.1 A/AA accessibility design notes:
    - Pseudo-link card pattern: only the card title is a real <a>, marked
      .stretched-link so a CSS ::after overlay makes the visible card area
      clickable. This keeps the link's accessible name short (just the plan
      name) and frees nested controls (favourite button, trail item links) to
      be their own native interactive elements (WCAG 2.4.4 Link Purpose,
      2.5.3 Label in Name, 4.1.1 Parsing — no nested interactives).
    - Trail items render as real <a> when clickable, otherwise as plain <li>
      content. Keyboard activation (Enter / Space) works natively (WCAG 2.1.1).
    - Trail-marker icons stay aria-hidden; completion status is communicated to
      assistive technology via a visually-hidden suffix ("— completed" /
      "— pending") so the meaning isn't conveyed by colour alone (WCAG 1.4.1).
    - Decorative gradient/halftone backgrounds are aria-hidden; only real photo
      images use role="img" with aria-label (WCAG 1.1.1).
    - Tag chips are exposed to AT inside a labelled group (WCAG 1.3.1).
    - The favourite button declares aria-pressed for explicit toggle semantics
      (WCAG 4.1.2).

    Example context (json):
    {
        "id": 10,
        "name": "Learning plan",
        "url": "#",
        "hasimage": false,
        "hastrail": true,
        "competencycounttext": "3 competencies",
        "trailclickable": false,
        "isvertical": true,
        "ishorizontal": false,
        "isfavourite": false,
        "trail": [
            {"shortname": "Competency A", "iscompleted": true, "isfirst": true, "islast": false},
            {"shortname": "Competency B", "iscompleted": false, "isfirst": false, "islast": true}
        ]
    }
}}
{{#isvertical}}
<article class="card plan-card h-100" aria-labelledby="plan-title-{{id}}" style="{{#hasbgcolor}}--dimension-custombgcolor: {{bgcolor}};{{/hasbgcolor}}{{#hastextcolor}}--dimension-customtextcolor: {{textcolor}};{{/hastextcolor}}">
    <button type="button"
            class="dims-fav-btn"
            data-fav-type="plan"
            data-fav-id="{{id}}"
            aria-label="{{favouritearialabel}}"
            aria-pressed="{{#isfavourite}}true{{/isfavourite}}{{^isfavourite}}false{{/isfavourite}}"
            title="{{favouritetitle}}">
        {{#isfavourite}}
        <i class="fa fa-star dims-fav-icon-filled" aria-hidden="true"></i>
        {{/isfavourite}}
        {{^isfavourite}}
        <i class="fa fa-star-o dims-fav-icon-empty" aria-hidden="true"></i>
        {{/isfavourite}}
    </button>
    <div class="plan-card-image-wrapper">
        {{#hasimage}}
        <div class="plan-card-image"
             role="img"
             aria-label="{{name}}"
             style="background-image: url('{{imageurl}}');"></div>
        {{/hasimage}}
        {{^hasimage}}
        <div class="plan-card-image plan-card-gradient{{#hasbgcolor}} has-custom-bg{{/hasbgcolor}}"
             aria-hidden="true"
             style="{{#hasbgcolor}}background: var(--dimension-custombgcolor);{{/hasbgcolor}}"></div>
        {{/hasimage}}
        {{#hastags}}
        <div class="dimension-tags" role="group" aria-label="{{#str}}cardtags, block_dimensions{{/str}}">
            {{#tags}}
            <span class="dimension-tag plan-tag">{{value}}</span>
            {{/tags}}
        </div>
        {{/hastags}}
        <span class="dims-card-access-btn" aria-hidden="true">
            {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
        </span>
    </div>
    <div class="card-body p-3">
        <h4 class="card-title mb-2 font-weight-bold text-dark" id="plan-title-{{id}}">
            <a href="{{url}}" class="plan-card-link stretched-link text-decoration-none text-dark">{{name}}</a>
        </h4>
        <p class="competency-count-text">{{competencycounttext}}</p>
        {{#hastrail}}
        <ul class="competency-trail{{#hasitemsbeforetrail}} has-before{{/hasitemsbeforetrail}}{{#hasitemsaftertrail}} has-after{{/hasitemsaftertrail}}"
            aria-label="{{#str}}competencytrail, block_dimensions{{/str}}">
            {{#trail}}
            <li class="trail-item {{#iscompleted}}completed{{/iscompleted}} {{#isfirst}}first{{/isfirst}} {{#islast}}last{{/islast}}{{#trailclickable}} clickable{{/trailclickable}}">
                {{#trailclickable}}
                <a href="{{url}}" class="trail-item-link" data-trail-planid="{{planid}}">
                    <span class="trail-marker" aria-hidden="true">
                        {{#iscompleted}}<i class="fa fa-check-circle text-success"></i>{{/iscompleted}}
                        {{^iscompleted}}<span class="empty-circle"></span>{{/iscompleted}}
                    </span>
                    <span class="trail-label {{#iscompleted}}text-success{{/iscompleted}}">{{shortname}}</span>
                    <span class="sr-only"> — {{#iscompleted}}{{#str}}status_completed, block_dimensions{{/str}}{{/iscompleted}}{{^iscompleted}}{{#str}}status_pending, block_dimensions{{/str}}{{/iscompleted}}</span>
                </a>
                {{/trailclickable}}
                {{^trailclickable}}
                <span class="trail-marker" aria-hidden="true">
                    {{#iscompleted}}<i class="fa fa-check-circle text-success"></i>{{/iscompleted}}
                    {{^iscompleted}}<span class="empty-circle"></span>{{/iscompleted}}
                </span>
                <span class="trail-label {{#iscompleted}}text-success{{/iscompleted}}">{{shortname}}</span>
                <span class="sr-only"> — {{#iscompleted}}{{#str}}status_completed, block_dimensions{{/str}}{{/iscompleted}}{{^iscompleted}}{{#str}}status_pending, block_dimensions{{/str}}{{/iscompleted}}</span>
                {{/trailclickable}}
            </li>
            {{/trail}}
        </ul>
        {{/hastrail}}
    </div>
</article>
{{/isvertical}}
{{#ishorizontal}}
<article class="card plan-card plan-card-horizontal h-100" aria-labelledby="plan-title-{{id}}" style="{{#hasbgcolor}}--dimension-custombgcolor: {{bgcolor}};{{/hasbgcolor}}{{#hastextcolor}}--dimension-customtextcolor: {{textcolor}};{{/hastextcolor}}">
    <button type="button"
            class="dims-fav-btn"
            data-fav-type="plan"
            data-fav-id="{{id}}"
            aria-label="{{favouritearialabel}}"
            aria-pressed="{{#isfavourite}}true{{/isfavourite}}{{^isfavourite}}false{{/isfavourite}}"
            title="{{favouritetitle}}">
        {{#isfavourite}}
        <i class="fa fa-star dims-fav-icon-filled" aria-hidden="true"></i>
        {{/isfavourite}}
        {{^isfavourite}}
        <i class="fa fa-star-o dims-fav-icon-empty" aria-hidden="true"></i>
        {{/isfavourite}}
    </button>
    <div class="plan-card-image-wrapper plan-card-image-wrapper-horizontal">
        {{#hasimage}}
        <div class="plan-card-image plan-card-image-horizontal"
             role="img"
             aria-label="{{name}}"
             style="background-image: url('{{imageurl}}');"></div>
        {{/hasimage}}
        {{^hasimage}}
        <div class="plan-card-image plan-card-image-horizontal plan-card-gradient{{#hasbgcolor}} has-custom-bg{{/hasbgcolor}}"
             aria-hidden="true"
             style="{{#hasbgcolor}}background: var(--dimension-custombgcolor);{{/hasbgcolor}}"></div>
        {{/hasimage}}
        <span class="dims-card-access-btn dims-card-access-btn-horizontal" aria-hidden="true">
            {{buttonlabel}} <i class="fa fa-arrow-right" aria-hidden="true"></i>
        </span>
        {{#hastags}}
        <div class="dimension-tags" role="group" aria-label="{{#str}}cardtags, block_dimensions{{/str}}">
            {{#tags}}
            <span class="dimension-tag plan-tag">{{value}}</span>
            {{/tags}}
        </div>
        {{/hastags}}
    </div>
    <div class="card-body plan-card-body-horizontal p-3">
        <h4 class="card-title mb-1 font-weight-bold text-dark" id="plan-title-{{id}}">
            <a href="{{url}}" class="plan-card-link stretched-link text-decoration-none text-dark">{{name}}</a>
        </h4>
        <p class="competency-count-text mb-2">{{competencycounttext}}</p>
        {{#hastrail}}
        <ul class="competency-trail competency-trail-vertical{{#hasitemsbeforetrail}} has-before{{/hasitemsbeforetrail}}{{#hasitemsaftertrail}} has-after{{/hasitemsaftertrail}}"
            aria-label="{{#str}}competencytrail, block_dimensions{{/str}}">
            {{#trail}}
            <li class="trail-item trail-item-vertical {{#iscompleted}}completed{{/iscompleted}} {{#isfirst}}first{{/isfirst}} {{#islast}}last{{/islast}}{{#trailclickable}} clickable{{/trailclickable}}">
                {{#trailclickable}}
                <a href="{{url}}" class="trail-item-link" data-trail-planid="{{planid}}">
                    <span class="trail-marker" aria-hidden="true">
                        {{#iscompleted}}<i class="fa fa-check-circle text-success"></i>{{/iscompleted}}
                        {{^iscompleted}}<span class="empty-circle"></span>{{/iscompleted}}
                    </span>
                    <span class="trail-label {{#iscompleted}}text-success{{/iscompleted}}">{{shortname}}</span>
                    <span class="sr-only"> — {{#iscompleted}}{{#str}}status_completed, block_dimensions{{/str}}{{/iscompleted}}{{^iscompleted}}{{#str}}status_pending, block_dimensions{{/str}}{{/iscompleted}}</span>
                </a>
                {{/trailclickable}}
                {{^trailclickable}}
                <span class="trail-marker" aria-hidden="true">
                    {{#iscompleted}}<i class="fa fa-check-circle text-success"></i>{{/iscompleted}}
                    {{^iscompleted}}<span class="empty-circle"></span>{{/iscompleted}}
                </span>
                <span class="trail-label {{#iscompleted}}text-success{{/iscompleted}}">{{shortname}}</span>
                <span class="sr-only"> — {{#iscompleted}}{{#str}}status_completed, block_dimensions{{/str}}{{/iscompleted}}{{^iscompleted}}{{#str}}status_pending, block_dimensions{{/str}}{{/iscompleted}}</span>
                {{/trailclickable}}
            </li>
            {{/trail}}
        </ul>
        {{/hastrail}}
    </div>
</article>
{{/ishorizontal}}
